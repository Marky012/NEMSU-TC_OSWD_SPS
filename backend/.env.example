# --- Required ---
SECRET_KEY=generate-a-random-64-char-secret-key
ADMIN_INITIAL_PASSWORD=changeme123
DATABASE_URL=postgresql://user:password@host:5432/oswd_sps

# --- Optional (defaults below) ---
ENVIRONMENT=development
ALLOWED_ORIGINS_STR=*
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- SMTP (leave empty to mock) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=oswd@nemsu.edu.ph
SMTP_FROM_NAME=NEMSU OSWD Office

# --- Admin seed ---
ADMIN_INITIAL_EMAIL=admin@nemsu.edu.ph

# --- Rate Limiting ---
LOGIN_RATE_LIMIT=5/minute
API_RATE_LIMIT=100/minute

# --- CSRF ---
CSRF_ENABLED=True
CSRF_SECRET_KEY=
